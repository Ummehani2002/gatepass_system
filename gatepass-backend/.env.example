# ── Postgres connection ────────────────────────────────────────────
# Either set DATABASE_URL (preferred for hosted DBs like Neon)…
DATABASE_URL=postgres://postgres:postgres@localhost:5432/acacia_gatepass

# …or set the individual parts (used only if DATABASE_URL is empty):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=acacia_gatepass

# Set to "true" when connecting to a hosted DB that requires SSL (Neon, Render, etc.)
PGSSL=false

# ── App ────────────────────────────────────────────────────────────
PORT=4000

# Secret used to sign login tokens — change this to a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of origins allowed to call the API.
# Use * during local development. After Vercel deploy, set to your Vercel URL
# (CORS_ORIGIN = the Vercel frontend origin).
CORS_ORIGIN=*
