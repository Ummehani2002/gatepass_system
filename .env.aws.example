# Copy to .env.aws on the EC2 host (never commit real secrets).

# Neon / RDS connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
PGSSL=true

# Long random string (openssl rand -base64 32)
JWT_SECRET=change-me

# Public URLs after EC2 has an Elastic IP / domain
# Example if only using the EC2 public IP:
#   NEXT_PUBLIC_APP_URL=http://54.x.x.x
#   NEXT_PUBLIC_API_URL=http://54.x.x.x:4000
#   CORS_ORIGIN=http://54.x.x.x
NEXT_PUBLIC_APP_URL=http://YOUR_EC2_PUBLIC_IP
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP:4000
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP
