# Postgres connection string (Neon, Supabase, RDS, or local Postgres all work)
# Only required if you use leftover TaskFlow routes (/login, org dashboards).
# Gate Pass (the "/" app) uses NEXT_PUBLIC_API_URL → gatepass-backend instead.
DATABASE_URL="postgres://user:password@localhost:5432/taskflow"

# Random 32+ byte secret used to sign TaskFlow session JWTs.
# Leave unset for Gate Pass-only deploys (middleware will skip TaskFlow auth).
AUTH_SECRET=""

# Optional: Upstash Redis, used for rate limiting. App falls back to in-memory
# rate limiting (single-instance only) if these are not set.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Base URL of the app (Vercel URL after deploy)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Gate Pass shared database API (Render URL after deploy).
# When set, the UI stores data in Postgres via gatepass-backend.
# When empty, the UI uses browser localStorage (local demo mode).
NEXT_PUBLIC_API_URL="http://localhost:4000"
