# Postgres connection string (Neon, Supabase, RDS, or local Postgres all work)
DATABASE_URL="postgres://user:password@localhost:5432/taskflow"

# Random 32+ byte secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional: Upstash Redis, used for rate limiting. App falls back to in-memory
# rate limiting (single-instance only) if these are not set.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Base URL of the app, used for building absolute links (e.g. invite emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
